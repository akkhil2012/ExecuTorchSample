#!/usr/bin/env python3
"""
Qwen 2 0.5B export with static cache for ExecuTorch compatibility.
"""

import torch
import torch.nn as nn
from transformers import AutoModelForCausalLM, AutoTokenizer
from pipeline import ExportConfig, ModelType, Backend, QuantizationMode, run_pipeline

class StaticCacheQwen2(nn.Module):
    """
    Wrapper for Qwen 2 0.5B with static cache to make it exportable.
    
    The original Qwen 2 uses DynamicCache which is not supported by torch.export.
    This wrapper converts it to static cache for compatibility.
    """
    
    def __init__(self, model_name: str = "Qwen/Qwen2-0.5B"):
        super().__init__()
        self.model = AutoModelForCausalLM.from_pretrained(
            model_name,
            torch_dtype=torch.float32,
            trust_remote_code=True
        )
        self.config = self.model.config
        
    def forward(self, input_ids, use_cache=False, past_key_values=None, attention_mask=None):
        """
        Forward pass with static cache support.
        
        Args:
            input_ids: Token IDs [batch, seq_len]
            use_cache: Whether to use cache (disabled for export)
            past_key_values: Past key values (disabled for export)
            attention_mask: Attention mask
            
        Returns:
            Model outputs with logits
        """
        # Disable cache for export compatibility
        outputs = self.model(
            input_ids=input_ids,
            use_cache=False,  # Disable dynamic cache
            past_key_values=None,
            attention_mask=attention_mask,
            output_attentions=False,
            output_hidden_states=False,
            return_dict=False
        )
        
        # Return only logits for simplicity
        if isinstance(outputs, tuple):
            return outputs[0]  # logits
        else:
            return outputs.logits

def main():
    print("🚀 Qwen 2 0.5B Static Cache Export for Android")
    print("=" * 60)
    
    # Test static cache model
    print("\n1. Testing static cache model...")
    try:
        model = StaticCacheQwen2()
        tokenizer = AutoTokenizer.from_pretrained("Qwen/Qwen2-0.5B", trust_remote_code=True)
        
        # Test forward pass
        test_input = torch.randint(1, tokenizer.vocab_size, (1, 64), dtype=torch.long)
        with torch.no_grad():
            output = model(test_input)
            print(f"✅ Static cache model works!")
            print(f"   Input shape: {test_input.shape}")
            print(f"   Output shape: {output.shape}")
            
    except Exception as e:
        print(f"❌ Static cache model failed: {e}")
        return
    
    # Export with static cache model
    print("\n2. Exporting static cache model...")
    
    # Create custom export function
    def export_static_qwen():
        """Export function that uses our static cache model."""
        from pipeline import load_model
        
        # Create config
        config = ExportConfig(
            model_type=ModelType.CUSTOM,  # Use custom to override loading
            backend=Backend.XNNPACK,
            quantization=QuantizationMode.NONE,
            input_shape=(1, 64),  # Small sequence length for safety
            output_name="qwen2_0_5b_static",
            output_dir="./android_models",
            dynamic_shapes=False,
            validate=True,
            profile=True,
        )
        
        # Override model loading with our static cache model
        static_model = StaticCacheQwen2()
        static_model.eval()
        
        # Create appropriate example inputs
        batch_size, seq_length = config.input_shape
        tokenizer = AutoTokenizer.from_pretrained("Qwen/Qwen2-0.5B", trust_remote_code=True)
        example_inputs = (torch.randint(1, tokenizer.vocab_size, (batch_size, seq_length), dtype=torch.long),)
        
        print(f"Configuration:")
        print(f"  Model: Static Cache Qwen 2 0.5B")
        print(f"  Backend: {config.backend}")
        print(f"  Input shape: {config.input_shape}")
        
        # Run pipeline stages manually
        from pipeline import export_model, lower_to_edge, serialize_to_pte, validate_pte, profile_model
        
        try:
            # Stage 3: Export
            print("\n  Stage 3/7: torch.export...")
            exported_program = export_model(static_model, example_inputs, config)
            
            # Stage 4: Lower to edge
            print("  Stage 4/7: Edge lowering...")
            edge_program = lower_to_edge(exported_program, config)
            
            # Stage 5: Serialize
            print("  Stage 5/7: Serialization...")
            pte_path = serialize_to_pte(edge_program, config)
            
            # Stage 6: Validate
            if config.validate:
                print("  Stage 6/7: Validation...")
                validate_pte(pte_path, example_inputs, static_model)
            
            # Stage 7: Profile
            if config.profile:
                print("  Stage 7/7: Profiling...")
                profile_model(static_model, pte_path, config)
            
            return pte_path
            
        except Exception as e:
            print(f"\n❌ Export failed: {e}")
            raise
    
    try:
        pte_path = export_static_qwen()
        print(f"\n✅ Static cache export completed!")
        print(f"📱 Android-ready model saved to: {pte_path}")
        
        print(f"\n📋 Next steps:")
        print(f"   1. Copy .pte file to Android app assets")
        print(f"   2. Load with ExecuTorch Module.load()")
        print(f"   3. Use tokenizer for text preprocessing")
        
    except Exception as e:
        print(f"\n❌ Static cache export failed: {e}")
        print("\n💡 Alternative solutions:")
        print("   1. Try smaller sequence length (1x32)")
        print("   2. Use older Qwen version")
        print("   3. Consider different model (MobileBERT, DistilBERT)")

if __name__ == "__main__":
    main()
